.profile-panel {
  padding: 34rpx;
}

.profile-name,
.profile-meta {
  display: block;
}

.profile-name {
  color: #1f3a35;
  font-size: 42rpx;
  font-weight: 800;
}

.profile-meta {
  margin-top: 10rpx;
  color: #81776e;
}

.stats-grid {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.stat-card {
  min-height: 160rpx;
  padding: 26rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.stat-number {
  color: #27302d;
  font-size: 44rpx;
  font-weight: 800;
}

.stat-label {
  margin-top: 8rpx;
  color: #81776e;
}

.roadmap-panel {
  padding: 18rpx 24rpx;
}

.roadmap-item {
  min-height: 74rpx;
  display: flex;
  align-items: center;
  color: #3e4541;
  border-bottom: 1rpx solid #efe4da;
}

.roadmap-item:last-child {
  border-bottom: 0;
}
