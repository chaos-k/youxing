.result-page {
  padding-bottom: 170rpx;
}

.report-head {
  padding: 32rpx;
}

.report-kicker,
.report-title,
.report-summary {
  display: block;
}

.report-kicker {
  color: #956746;
  font-size: 24rpx;
  font-weight: 700;
}

.report-title {
  margin-top: 8rpx;
  color: #1f3a35;
  font-size: 42rpx;
  font-weight: 800;
}

.report-summary {
  margin-top: 16rpx;
  color: #605850;
  line-height: 1.7;
}

.keyword-row {
  margin-top: 22rpx;
}

.profile-tags {
  margin-bottom: 4rpx;
}

.outfit-panel {
  padding: 24rpx;
}

.outfit-item {
  padding: 20rpx 0;
  color: #27302d;
  line-height: 1.6;
  border-bottom: 1rpx solid #efe4da;
}

.outfit-item:last-child {
  border-bottom: 0;
}

.color-panel {
  padding: 22rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18rpx;
}

.swatch-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #4c514d;
  font-size: 24rpx;
}

.swatch {
  width: 36rpx;
  height: 36rpx;
  flex: 0 0 36rpx;
  border: 1rpx solid rgba(31, 36, 33, 0.12);
  border-radius: 50%;
}

.advice-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.advice-card {
  padding: 26rpx;
}

.advice-title {
  display: block;
  color: #27302d;
  font-size: 32rpx;
  font-weight: 800;
}

.pill-row {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.pill {
  padding: 12rpx 16rpx;
  color: #1f3a35;
  background: #edf4ee;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.advice-reason {
  display: block;
  margin-top: 18rpx;
  color: #6f655b;
  line-height: 1.7;
}

.avoid-row {
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #efe4da;
  line-height: 1.6;
}

.avoid-label {
  margin-right: 12rpx;
  color: #9b583c;
  font-weight: 700;
}

.avoid-text {
  color: #766a60;
}

.avoid-panel {
  padding: 24rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.avoid-tag {
  padding: 12rpx 16rpx;
  color: #7d3f2b;
  background: #f8e7dc;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.result-actions {
  position: fixed;
  right: 28rpx;
  bottom: 40rpx;
  left: 28rpx;
  display: grid;
  grid-template-columns: 1fr 1fr 1.4fr;
  gap: 16rpx;
}
